# gcp-mcp 共通の環境変数テンプレ。
# 実値は ~/.config/devsbx/gcp-mcp.env に配置する（recipe 外）:
#   mkdir -p ~/.config/devsbx
#   cp .env.example ~/.config/devsbx/gcp-mcp.env
#   chmod 600 ~/.config/devsbx/gcp-mcp.env

# 対象とする GCP プロジェクト ID。
# - GOOGLE_CLOUD_PROJECT: google-auth ライブラリ / 多くの SDK が読む標準名
# - CLOUDSDK_CORE_PROJECT: gcloud CLI が読む名前
# 両者は同じ値にする。container 内で gcloud が `--project` 不要で動くように両方設定する。
GOOGLE_CLOUD_PROJECT=your-project-id
CLOUDSDK_CORE_PROJECT=your-project-id

# AI agent に impersonate させる sandbox SA。
# 個人アカウントや全権 SA は絶対に指定しないこと。
# 推奨 IAM 設計（README の「sandbox SA の用意」節を参照）:
#   - 触れる API ごとに最小権限ロールを個別に付ける (例: smoke 前提の roles/artifactregistry.reader、Cloud Logging 閲覧の roles/logging.viewer)
#   - 絶対に付けない: roles/owner, roles/editor, roles/viewer, roles/iam.*, roles/billing.*, deploy 系
IMPERSONATE_SERVICE_ACCOUNT=claude-sandbox@your-project-id.iam.gserviceaccount.com
