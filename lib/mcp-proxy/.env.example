# lib/mcp-proxy/ を利用する全 recipe で共有する Bearer token テンプレ。
# 配置先: ~/.config/devsbx/mcp-proxy.env
# パーミッション: 600 推奨。
#
# 役割:
# - 各 mcp-* proxy の incoming Bearer 認証 (--token / PROXY_TOKEN)
# - workspace が `.mcp.json` の headers で参照する (Authorization: Bearer ${PROXY_TOKEN})
#
# 同じ 1 値を全 mcp-* proxy + 全 workspace で共有する設計 (recipe レベルでの fail-closed)。
#
# セットアップ手順:
#   mkdir -p ~/.config/devsbx
#   printf 'PROXY_TOKEN=%s\n' "$(openssl rand -hex 32)" \
#     > ~/.config/devsbx/mcp-proxy.env
#   chmod 600 ~/.config/devsbx/mcp-proxy.env

PROXY_TOKEN=please-replace-with-openssl-rand-hex-32
