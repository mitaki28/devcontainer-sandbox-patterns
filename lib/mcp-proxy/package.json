{
  "name": "mcp-proxy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build:linux-x64 && bun run build:linux-arm64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/mcp-proxy-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/mcp-proxy-linux-arm64",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "typescript": "^6.0.3"
  }
}
